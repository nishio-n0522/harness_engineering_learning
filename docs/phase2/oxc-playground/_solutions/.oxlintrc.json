{
  "$schema": "../node_modules/oxlint/configuration_schema.json",
  "categories": {
    "correctness": "error",
    "suspicious": "warn"
  },
  "plugins": [
    "typescript",
    "react",
    "react-perf",
    "jsx-a11y",
    "import",
    "unicorn",
    "oxc"
  ],
  "env": {
    "builtin": true,
    "browser": true,
    "node": true,
    "es2024": true
  }
}
