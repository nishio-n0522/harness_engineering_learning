{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "lib": ["ES2022"],
    "types": ["node"],
    "noEmit": true
  },
  "include": ["scripts/**/*"],
  "exclude": ["fixtures/**/*", "node_modules"]
}
